# 가상환경 파일
.venv/

# 캐시 파일
__pycache__/
*.pyc
.pytest_cache/

# 로그 파일
*.log

# 환경 변수 파일
.env

# 데이터 파일
data/

# 모델 파일
models/

# 결과 파일
results/

# 기타
*.tmp
*.bak
claude.md
# docs/는 기본적으로 무시(설치된 프로젝트가 만드는 프로젝트별 문서 폴더용)하되,
# 프레임워크 자체 문서(docs/OPEN_MODEL.md 등)는 예외로 추적한다.
docs/*
!docs/OPEN_MODEL.md
samples/
.claude/
venv